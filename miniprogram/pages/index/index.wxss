page {
  background: #f6f7f9;
  color: #1f2329;
}

.page {
  padding-bottom: 56rpx;
}

.hero {
  min-height: 620rpx;
  display: flex;
  align-items: flex-end;
  padding: 44rpx 30rpx;
  box-sizing: border-box;
  color: #fff;
  background: linear-gradient(180deg, rgba(18, 24, 32, 0.28), rgba(18, 24, 32, 0.82)),
    url("https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?auto=format&fit=crop&w=1200&q=80");
  background-size: cover;
  background-position: center;
}

.hero-content {
  width: 100%;
}

.brand {
  font-size: 30rpx;
  font-weight: 800;
}

.title {
  width: 92%;
  margin-top: 20rpx;
  font-size: 56rpx;
  line-height: 1.14;
  font-weight: 900;
}

.subtitle {
  width: 90%;
  margin-top: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.9;
}

.hero-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 34rpx;
}

.primary,
.secondary,
.full-cta {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.primary {
  width: 246rpx;
  color: #fff;
  background: #e23d28;
}

.secondary {
  width: 260rpx;
  color: #1f2329;
  background: #fff;
}

.planner,
.flow,
.feature-card,
.status-card,
.diagnostics-panel {
  margin: 24rpx 28rpx 0;
  padding: 30rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
}

.env-badge {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef3f8;
  color: #385170;
  font-size: 22rpx;
}

.field {
  margin-top: 26rpx;
}

.section-gap {
  margin-top: 32rpx;
}

.prompt-box {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
}

.prompt-input {
  width: 100%;
  min-height: 132rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.prompt-hints {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.prompt-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #385170;
  font-size: 24rpx;
}

.field-label {
  margin-bottom: 14rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.segmented {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.segment {
  min-width: 136rpx;
  height: 62rpx;
  line-height: 62rpx;
  padding: 0 18rpx;
  text-align: center;
  border: 1rpx solid #d5dbe3;
  border-radius: 6rpx;
  color: #4b5563;
  background: #fff;
  font-size: 25rpx;
  box-sizing: border-box;
}

.segment.active {
  border-color: #1f8a70;
  color: #176b57;
  background: #eef6f4;
  font-weight: 800;
}

.full-cta {
  width: 100%;
  margin-top: 30rpx;
  color: #fff;
  background: #1f8a70;
}

.status {
  margin-top: 18rpx;
  color: #5f6c7b;
  font-size: 24rpx;
  line-height: 1.5;
}

.status-grid {
  margin-top: 6rpx;
}

.status-card {
  margin-top: 18rpx;
}

.status-card-title {
  font-size: 28rpx;
  font-weight: 800;
}

.status-card-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #5f6c7b;
}

.status-ready {
  border-left: 8rpx solid #1f8a70;
}

.status-fallback {
  border-left: 8rpx solid #e4552d;
}

.status-degraded {
  border-left: 8rpx solid #d97706;
}

.diagnostic-card {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.diag-ready {
  border-left: 8rpx solid #1f8a70;
}

.diag-fallback {
  border-left: 8rpx solid #e4552d;
}

.diag-degraded {
  border-left: 8rpx solid #d97706;
}

.diagnostic-title {
  font-size: 27rpx;
  font-weight: 800;
}

.diagnostic-detail,
.diagnostic-action {
  margin-top: 8rpx;
  color: #5f6c7b;
  font-size: 24rpx;
  line-height: 1.55;
}

.diagnostic-action {
  color: #334e68;
}

.flow-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 22rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.flow-item {
  flex: 0 0 auto;
  padding: 14rpx 18rpx;
  border-radius: 6rpx;
  color: #176b57;
  background: #eef6f4;
  font-size: 24rpx;
  font-weight: 700;
}

.flow-arrow {
  color: #9ca3af;
  font-size: 26rpx;
}

.features {
  margin-top: 24rpx;
}

.feature-card {
  margin-top: 18rpx;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 800;
}

.feature-desc {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.55;
}
