<view class="page">
  <view class="hero">
    <view class="hero-content">
      <view class="brand">TravelAgent</view>
      <view class="title">微信旅行规划 + Trip 门票转化闭环</view>
      <view class="subtitle">输入旅行需求，生成 1-3 天结构化行程，承接到真实 Trip 城市活动页；云端异常时自动切稳定兜底。</view>
      <view class="hero-actions">
        <button class="primary" bindtap="goChatBot">开始 AI 对话</button>
        <button class="secondary" bindtap="generatePlan" loading="{{loading}}">直接生成结果</button>
      </view>
    </view>
  </view>

  <view class="planner">
    <view class="section-title">自然语言快速生成</view>
    <view class="env-badge">当前环境：{{runtimeEnv}}</view>
    <view class="prompt-box">
      <textarea
        class="prompt-input"
        value="{{prompt}}"
        placeholder="例如：东京情侣 3 天，想看夜景和沉浸式展览"
        auto-height
        maxlength="120"
        bindinput="handlePromptInput"
      />
      <view class="prompt-hints">
        <block wx:for="{{quickPrompts}}" wx:key="*this">
          <view class="prompt-chip" data-prompt="{{item}}" bindtap="useQuickPrompt">{{item}}</view>
        </block>
      </view>
    </view>

    <view class="section-title section-gap">快捷条件</view>
    <view class="field">
      <view class="field-label">目的地</view>
      <view class="segmented">
        <block wx:for="{{cities}}" wx:key="*this">
          <view class="segment {{city === item ? 'active' : ''}}" data-city="{{item}}" bindtap="selectCity">{{item}}</view>
        </block>
      </view>
    </view>
    <view class="field">
      <view class="field-label">天数</view>
      <view class="segmented">
        <block wx:for="{{dayOptions}}" wx:key="*this">
          <view class="segment {{days === item ? 'active' : ''}}" data-days="{{item}}" bindtap="selectDays">{{item}} 天</view>
        </block>
      </view>
    </view>
    <view class="field">
      <view class="field-label">偏好</view>
      <view class="segmented">
        <block wx:for="{{typeOptions}}" wx:key="key">
          <view class="segment {{type === item.key ? 'active' : ''}}" data-type="{{item.key}}" bindtap="selectType">{{item.label}}</view>
        </block>
      </view>
    </view>
    <button class="full-cta" bindtap="generatePlan" loading="{{loading}}">
      {{loading ? '生成中...' : '查看行程与门票'}}
    </button>
    <view class="status" wx:if="{{statusText}}">{{statusText}}</view>
  </view>

  <view class="status-grid" wx:if="{{integrationStatus && planStatus && purchaseStatus}}">
    <view class="status-card status-{{integrationStatus.level}}">
      <view class="status-card-title">{{integrationStatus.title}}</view>
      <view class="status-card-desc">{{integrationStatus.detail}}</view>
    </view>
    <view class="status-card status-{{planStatus.level}}">
      <view class="status-card-title">{{planStatus.title}}</view>
      <view class="status-card-desc">{{planStatus.detail}}</view>
    </view>
    <view class="status-card status-{{purchaseStatus.level}}">
      <view class="status-card-title">{{purchaseStatus.title}}</view>
      <view class="status-card-desc">{{purchaseStatus.detail}}</view>
    </view>
  </view>

  <view class="flow">
    <view class="section-title">MVP 链路</view>
    <view class="flow-row">
      <view class="flow-item">用户输入</view>
      <view class="flow-arrow">→</view>
      <view class="flow-item">AI 行程</view>
      <view class="flow-arrow">→</view>
      <view class="flow-item">POI 推荐</view>
      <view class="flow-arrow">→</view>
      <view class="flow-item">Trip 门票</view>
    </view>
  </view>

  <view class="features">
    <block wx:for="{{highlights}}" wx:key="title">
      <view class="feature-card">
        <view class="feature-title">{{item.title}}</view>
        <view class="feature-desc">{{item.desc}}</view>
      </view>
    </block>
  </view>
</view>
