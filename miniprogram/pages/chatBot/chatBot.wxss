.chat-page {
  min-height: 100vh;
  background: #f6f7f9;
  padding-bottom: 40rpx;
}

.top-card {
  margin: 20rpx 20rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.06);
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  align-items: center;
}

.top-title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 800;
}

.top-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.result-btn {
  flex-shrink: 0;
  width: 150rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  border-radius: 12rpx;
  color: #fff;
  background: #1f8a70;
  font-size: 24rpx;
  font-weight: 700;
}

.composer-card,
.preview-card,
.agent-panel {
  margin: 20rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.06);
}

.composer-title,
.agent-title {
  font-size: 30rpx;
  font-weight: 800;
}

.composer-input {
  width: 100%;
  min-height: 140rpx;
  margin-top: 18rpx;
  padding: 18rpx 0;
  font-size: 28rpx;
  line-height: 1.6;
}

.quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 8rpx;
}

.quick-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef3f8;
  color: #334e68;
  font-size: 24rpx;
}

.primary-btn,
.mini-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.primary-btn {
  margin-top: 20rpx;
  color: #fff;
  background: #e4552d;
}

.mini-btn {
  padding: 0 24rpx;
  background: #eef6f4;
  color: #1f8a70;
}

.status-text {
  margin-top: 16rpx;
  color: #52606d;
  font-size: 24rpx;
  line-height: 1.5;
}

.status-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.status-card {
  padding: 20rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.status-card-title {
  font-size: 26rpx;
  font-weight: 800;
}

.status-card-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.55;
  color: #61707f;
}

.status-ready {
  border-left: 8rpx solid #1f8a70;
}

.status-fallback {
  border-left: 8rpx solid #e4552d;
}

.status-degraded {
  border-left: 8rpx solid #d97706;
}

.fallback-banner,
.preview-warning {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #fff7e6;
  color: #8d5b00;
  font-size: 24rpx;
  line-height: 1.55;
}

.preview-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.preview-title {
  font-size: 30rpx;
  font-weight: 800;
}

.preview-meta {
  margin-top: 8rpx;
  color: #61707f;
  font-size: 24rpx;
}
