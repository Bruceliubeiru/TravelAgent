page {
  background: #f6f7f9;
  color: #1f2329;
}

.page {
  padding-bottom: 150rpx;
}

.empty-page {
  padding: 28rpx;
}

.header {
  position: relative;
  height: 500rpx;
  overflow: hidden;
}

.header-bg,
.header-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.header-mask {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.24), rgba(0, 0, 0, 0.72));
}

.header-nav {
  position: absolute;
  top: 82rpx;
  left: 28rpx;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-back {
  width: 30rpx;
  height: 30rpx;
}

.header-content {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 42rpx;
  color: #fff;
}

.label {
  font-size: 24rpx;
  opacity: 0.82;
}

.poi-name {
  margin-top: 12rpx;
  font-size: 48rpx;
  line-height: 1.16;
  font-weight: 800;
}

.poi-reason {
  margin-top: 14rpx;
  font-size: 27rpx;
  line-height: 1.5;
  opacity: 0.9;
}

.panel {
  margin: 24rpx 28rpx 0;
  padding: 30rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.06);
}

.ticket-title {
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  margin-top: 20rpx;
}

.status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.status-badge,
.mode-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-available {
  background: #ecfdf3;
  color: #027a48;
}

.status-limited {
  background: #fff7e6;
  color: #b26a00;
}

.status-unavailable {
  background: #fef2f2;
  color: #b42318;
}

.mode-badge {
  background: #eef3f8;
  color: #385170;
}

.price {
  color: #e23d28;
  font-size: 50rpx;
  font-weight: 900;
}

.origin {
  color: #9ca3af;
  font-size: 24rpx;
  text-decoration: line-through;
}

.score {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  color: #8a5a00;
  background: #fff2cf;
  font-size: 22rpx;
}

.benefit-list,
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.benefit,
.tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef6f4;
  color: #176b57;
  font-size: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
}

.body-text {
  margin-top: 16rpx;
  color: #4b5563;
  font-size: 27rpx;
  line-height: 1.65;
}

.subtle {
  color: #66788a;
  font-size: 24rpx;
}

.bottom-space {
  margin-bottom: 40rpx;
}

.empty-card {
  margin-top: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.06);
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx 34rpx;
  background: #fff;
  box-shadow: 0 -8rpx 24rpx rgba(31, 35, 41, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bottom-price {
  color: #e23d28;
  font-size: 38rpx;
  font-weight: 900;
}

.bottom-sub {
  margin-top: 4rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.buy-btn {
  width: 300rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 12rpx;
  background: #e23d28;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
}
