page {
  background: #f6f7f9;
  color: #1f2329;
}

.page {
  padding: 28rpx;
  padding-bottom: 64rpx;
}

.hero {
  min-height: 360rpx;
  padding: 48rpx 36rpx;
  border-radius: 16rpx;
  color: #fff;
  background: linear-gradient(135deg, rgba(20, 27, 34, 0.86), rgba(30, 79, 88, 0.82)),
    url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80");
  background-size: cover;
  background-position: center;
}

.eyebrow {
  font-size: 24rpx;
  opacity: 0.78;
}

.title {
  margin-top: 28rpx;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.14;
}

.subtitle {
  width: 88%;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.6;
  opacity: 0.88;
}

.meta-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 32rpx;
}

.meta {
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 999rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.12);
}

.notice-card,
.day-card,
.ticket-card,
.poi-card,
.empty-card {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.06);
}

.notice-card {
  color: #8d5b00;
  background: #fff7e6;
  font-size: 24rpx;
  line-height: 1.55;
}

.section {
  margin-top: 36rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-end;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.ghost-btn {
  flex-shrink: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d5dbe3;
  background: #fff;
  color: #293241;
  font-size: 24rpx;
}

.day-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.day-index {
  width: 62rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 50%;
  text-align: center;
  color: #fff;
  background: #1f8a70;
  font-size: 24rpx;
  font-weight: 700;
}

.day-theme {
  font-size: 30rpx;
  font-weight: 700;
}

.day-summary {
  margin-top: 18rpx;
  font-size: 27rpx;
  color: #4b5563;
  line-height: 1.55;
}

.poi-list,
.ticket-benefits {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.poi-chip,
.ticket-benefits text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef6f4;
  color: #176b57;
  font-size: 23rpx;
}

.poi-card {
  display: flex;
  gap: 22rpx;
}

.poi-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.poi-info {
  flex: 1;
}

.poi-title {
  font-size: 30rpx;
  font-weight: 800;
}

.poi-reason,
.ticket-note,
.poi-meta {
  margin-top: 10rpx;
  color: #61707f;
  font-size: 24rpx;
  line-height: 1.55;
}

.poi-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.poi-tags text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f6fa;
  color: #385170;
  font-size: 22rpx;
}

.ticket-card {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.ticket-main {
  flex: 1;
  min-width: 0;
}

.ticket-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.score {
  margin-top: 16rpx;
  color: #8a5a00;
  font-size: 23rpx;
}

.ticket-side {
  width: 188rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.status-badge {
  margin-top: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-available {
  background: #ecfdf3;
  color: #027a48;
}

.status-limited {
  background: #fff7e6;
  color: #b26a00;
}

.status-unavailable {
  background: #fef2f2;
  color: #b42318;
}

.price {
  color: #e23d28;
  font-size: 38rpx;
  font-weight: 800;
}

.origin {
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 22rpx;
  text-decoration: line-through;
}

.cta {
  width: 176rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin-top: 18rpx;
  border-radius: 12rpx;
  color: #fff;
  background: #e23d28;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-btn {
  width: 176rpx;
  height: 56rpx;
  line-height: 56rpx;
  margin-top: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d5dbe3;
  background: #fff;
  color: #385170;
  font-size: 22rpx;
  font-weight: 700;
}

.note {
  margin-top: 28rpx;
  padding: 22rpx;
  border-left: 6rpx solid #1f8a70;
  border-radius: 12rpx;
  background: #fff;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.55;
}
